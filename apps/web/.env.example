# Server-side target for the Next proxy at /api/pdfkit/* (PRD §15).
API_BASE_URL=http://127.0.0.1:8080

# Optional: call the Rust API directly from the browser instead of the proxy.
# If set, the API must allow this origin via CORS (PDFKIT_ALLOWED_ORIGINS).
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080
